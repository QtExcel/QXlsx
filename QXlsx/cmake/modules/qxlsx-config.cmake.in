# - Config information for QXlsx
# This file defines:
#
#  QXlsx_INCLUDE_DIR - the QXlsx include directory
#  QXlsx_LIBRARY - Link these to use QXlsx

SET(prefix "@CMAKE_INSTALL_PREFIX@")
SET(exec_prefix "@CMAKE_INSTALL_PREFIX@")
SET(QXlsx_FOUND "TRUE")

include(CMakeFindDependencyMacro)
find_dependency(Qt@QT_VERSION_MAJOR@ COMPONENTS Core Gui)

# Qt 6.10+ requires GuiPrivate to be found separately
if(@QT_VERSION_MAJOR@ EQUAL 6 AND Qt6Gui_VERSION VERSION_GREATER_EQUAL "6.10.0")
    find_dependency(Qt6 COMPONENTS GuiPrivate)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/@EXPORT_NAME@Targets.cmake")
